        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"email\": \"usuario@mercapleno.com\",\n  \"password\": \"123456\",\n  \"direccion\": \"Calle 123\",\n  \"fecha_nacimiento\": \"2000-01-01\",\n  \"id_rol\": 3,\n  \"id_tipo_identificacion\": 1,\n  \"numero_identificacion\": \"123456789\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Registrar usuario nuevo"
          },
          "response": []
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  if (data && data.token) {",
                  "    pm.collectionVariables.set('bearerToken', data.token);",
                  "    if (pm.environment) {",
                  "      pm.environment.set('bearerToken', data.token);",
                  "    }",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Iniciar sesion. Guarda el token automaticamente."
          },
          "response": []
        },
        {
          "name": "POST Verify Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"code\": \"{{verificationCode}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/verify-email",
            "description": "Verificar correo con codigo"
          },
          "response": []
        },
        {
          "name": "POST Resend Verification",
